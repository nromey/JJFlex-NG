<local:JJFlexDialog x:Class="JJFlexWpf.Dialogs.ScanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JJFlexWpf"
        Title="Scan Configuration"
        Width="400" Height="340"
        SizeToContent="Height">

    <StackPanel Margin="12">
        <!-- Frequency Range -->
        <GroupBox Header="Frequency Range" Margin="0,0,0,8"
                  AutomationProperties.Name="Frequency Range">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Start Freq:" VerticalAlignment="Center"
                           Margin="4"/>
                <TextBox x:Name="StartFreqBox" Grid.Row="0" Grid.Column="1" Margin="4"
                         AutomationProperties.Name="Start Frequency"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="End Freq:" VerticalAlignment="Center"
                           Margin="4"/>
                <TextBox x:Name="EndFreqBox" Grid.Row="1" Grid.Column="1" Margin="4"
                         AutomationProperties.Name="End Frequency"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Increment (kHz):" VerticalAlignment="Center"
                           Margin="4"/>
                <TextBox x:Name="IncrementBox" Grid.Row="2" Grid.Column="1" Margin="4"
                         AutomationProperties.Name="Frequency Increment in kHz"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Speed (tenths/sec):" VerticalAlignment="Center"
                           Margin="4"/>
                <TextBox x:Name="SpeedBox" Grid.Row="3" Grid.Column="1" Margin="4"
                         AutomationProperties.Name="Scan Speed in tenths of a second"/>
            </Grid>
        </GroupBox>

        <!-- Scan Control Buttons -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="S_tart Scan" MinWidth="80" Margin="0,0,8,0"
                    AutomationProperties.Name="Start Scan"
                    AutomationProperties.AcceleratorKey="Alt+T"
                    Click="StartButton_Click"/>
            <Button Content="_Cancel" AutomationProperties.AcceleratorKey="Alt+C" MinWidth="75" Margin="0,0,8,0" IsCancel="True"
                    AutomationProperties.Name="Cancel" Click="CancelButton_Click"/>
            <Button Content="C_lear" MinWidth="75"
                    AutomationProperties.Name="Clear"
                    AutomationProperties.AcceleratorKey="Alt+L"
                    Click="ClearButton_Click"/>
        </StackPanel>

        <!-- Saved Scans -->
        <GroupBox Header="Saved Scans" AutomationProperties.Name="Saved Scans">
            <StackPanel Orientation="Horizontal" Margin="4">
                <Button Content="_Use Saved" MinWidth="80" Margin="0,0,8,0"
                        AutomationProperties.Name="Use Saved"
                        AutomationProperties.AcceleratorKey="Alt+U"
                        Click="UseSavedButton_Click"/>
                <Button Content="_Save" AutomationProperties.AcceleratorKey="Alt+S" MinWidth="60" Margin="0,0,8,0"
                        AutomationProperties.Name="Save current scan settings" Click="SaveButton_Click"/>
                <Button x:Name="ReplaceButton" Content="_Replace" MinWidth="65" Margin="0,0,8,0"
                        IsEnabled="False"
                        AutomationProperties.Name="Replace"
                        AutomationProperties.AcceleratorKey="Alt+R"
                        Click="ReplaceButton_Click"/>
                <Button x:Name="RemoveButton" Content="Re_move" MinWidth="65"
                        IsEnabled="False"
                        AutomationProperties.Name="Remove"
                        AutomationProperties.AcceleratorKey="Alt+M"
                        Click="RemoveButton_Click"/>
            </StackPanel>
        </GroupBox>
    </StackPanel>
</local:JJFlexDialog>
