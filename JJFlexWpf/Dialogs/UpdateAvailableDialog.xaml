<local:JJFlexDialog x:Class="JJFlexWpf.Dialogs.UpdateAvailableDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JJFlexWpf"
        Title="Update available"
        Width="520" Height="380"
        ResizeMode="NoResize"
        AutomationProperties.Name="Update available">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeadlineText"
                   Grid.Row="0"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Margin="0,0,0,6"
                   AutomationProperties.Name="Update headline"/>

        <TextBlock x:Name="VersionsText"
                   Grid.Row="1"
                   Margin="0,0,0,6"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="Current and available versions"/>

        <TextBlock x:Name="SizeText"
                   Grid.Row="2"
                   Margin="0,0,0,6"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="Download size estimate"/>

        <TextBlock x:Name="ChangelogLinkText"
                   Grid.Row="3"
                   Margin="0,8,0,0"
                   VerticalAlignment="Top"
                   AutomationProperties.Name="Changelog">
            <Hyperlink x:Name="ChangelogHyperlink"
                       Click="ChangelogHyperlink_Click"
                       AutomationProperties.Name="Open changelog in browser">
                See what's changed
            </Hyperlink>
        </TextBlock>

        <TextBlock x:Name="ProgressText"
                   Grid.Row="4"
                   Margin="0,8,0,4"
                   TextWrapping="Wrap"
                   AutomationProperties.Name="Update progress"
                   AutomationProperties.LiveSetting="Polite"
                   Text=""/>

        <StackPanel Grid.Row="5" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="DownloadAndInstallButton"
                    Content="_Download and install"
                    MinWidth="160" Height="32" Margin="0,0,8,0"
                    IsDefault="True"
                    AutomationProperties.Name="Download and install update"
                    AutomationProperties.AcceleratorKey="Alt+D"
                    Click="DownloadAndInstallButton_Click"/>
            <Button x:Name="SkipButton"
                    Content="_Skip this version"
                    MinWidth="120" Height="32" Margin="0,0,8,0"
                    AutomationProperties.Name="Skip this version"
                    AutomationProperties.AcceleratorKey="Alt+S"
                    Click="SkipButton_Click"/>
            <Button x:Name="CancelButton"
                    Content="_Cancel"
                    MinWidth="80" Height="32"
                    IsCancel="True"
                    AutomationProperties.Name="Cancel - close this dialog and remind me later"
                    AutomationProperties.AcceleratorKey="Alt+C"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</local:JJFlexDialog>
