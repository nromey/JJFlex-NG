<local:JJFlexDialog x:Class="JJFlexWpf.Dialogs.ConnectionTesterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JJFlexWpf"
        Title="Connection Tester"
        Width="500" Height="450"
        AutomationProperties.Name="Connection Tester">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Radio list -->
        <TextBlock Grid.Row="0" Text="Select a radio to test:" Margin="0,0,0,4"
                   AutomationProperties.Name="Select a radio to test" />
        <ListBox Grid.Row="1" x:Name="RadioList" Margin="0,0,0,8"
                 AutomationProperties.Name="Available radios"
                 SelectionChanged="RadioList_SelectionChanged" />

        <!-- SmartLink button -->
        <Button Grid.Row="2" x:Name="SmartLinkButton" Content="Connect SmartLink"
                HorizontalAlignment="Left" Padding="12,4" Margin="0,0,0,8"
                AutomationProperties.Name="Connect SmartLink to discover remote radios"
                Click="SmartLinkButton_Click" />

        <!-- Test configuration -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Number of tests:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox x:Name="TestCountBox" Width="60" Text="25" VerticalAlignment="Center"
                     AutomationProperties.Name="Number of tests, minimum 25" />
            <TextBlock Text="Delay between (seconds):" VerticalAlignment="Center" Margin="16,0,8,0" />
            <TextBox x:Name="DelayBox" Width="60" Text="5" VerticalAlignment="Center"
                     AutomationProperties.Name="Delay between tests in seconds" />
        </StackPanel>

        <!-- Status -->
        <TextBlock Grid.Row="4" x:Name="StatusText" Text="Discover radios, then select one to test."
                   Margin="0,0,0,8" TextWrapping="Wrap"
                   AutomationProperties.Name="Status" />

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="StartButton" Content="Start Test" IsEnabled="False"
                    Padding="16,6" Margin="0,0,8,0"
                    AutomationProperties.Name="Start connection test"
                    Click="StartButton_Click" />
            <Button Content="Cancel" IsCancel="True" Padding="16,6"
                    AutomationProperties.Name="Cancel" />
        </StackPanel>
    </Grid>
</local:JJFlexDialog>
