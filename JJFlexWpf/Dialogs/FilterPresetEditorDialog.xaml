<local:JJFlexDialog x:Class="JJFlexWpf.Dialogs.FilterPresetEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:JJFlexWpf"
    Title="Edit Filter Presets"
    Width="440" Height="420"
    ResizeMode="NoResize"
    AutomationProperties.Name="Edit filter presets">
    <DockPanel Margin="12">
        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Style="{StaticResource ButtonPanel}">
            <Button Content="_OK" Style="{StaticResource OkButton}"
                    AutomationProperties.Name="OK"
                    Click="OkButton_Click"/>
            <Button Content="_Cancel" Style="{StaticResource CancelButton}"
                    AutomationProperties.Name="Cancel"
                    Click="CancelButton_Click"/>
        </StackPanel>

        <StackPanel>
            <!-- Mode selector -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Mode:" VerticalAlignment="Center"
                           Style="{StaticResource DialogLabel}" Margin="0,0,8,0"/>
                <ComboBox x:Name="ModeCombo" Width="120"
                          Style="{StaticResource DialogComboBox}"
                          AutomationProperties.Name="Filter preset mode"
                          SelectionChanged="ModeCombo_SelectionChanged"/>
            </StackPanel>

            <!-- Preset list -->
            <ListBox x:Name="PresetList" Height="200" Margin="0,0,0,8"
                     AutomationProperties.Name="Filter presets for selected mode"
                     SelectionChanged="PresetList_SelectionChanged"/>

            <!-- Action buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="AddButton" Content="_Add" Width="60" Margin="0,0,4,0"
                        AutomationProperties.Name="Add preset"
                        Click="AddButton_Click"/>
                <Button x:Name="EditButton" Content="_Edit" Width="60" Margin="0,0,4,0"
                        AutomationProperties.Name="Edit preset"
                        Click="EditButton_Click"/>
                <Button x:Name="DeleteButton" Content="_Delete" Width="60" Margin="0,0,4,0"
                        AutomationProperties.Name="Delete preset"
                        Click="DeleteButton_Click"/>
                <Button x:Name="MoveUpButton" Content="Move _Up" Width="70" Margin="0,0,4,0"
                        AutomationProperties.Name="Move preset up"
                        Click="MoveUpButton_Click"/>
                <Button x:Name="MoveDownButton" Content="Move Do_wn" Width="80" Margin="0,0,4,0"
                        AutomationProperties.Name="Move preset down"
                        Click="MoveDownButton_Click"/>
            </StackPanel>

            <Button x:Name="ResetButton" Content="_Reset to Defaults"
                    Width="140" HorizontalAlignment="Left"
                    AutomationProperties.Name="Reset presets to defaults for this mode"
                    Click="ResetButton_Click"/>
        </StackPanel>
    </DockPanel>
</local:JJFlexDialog>
