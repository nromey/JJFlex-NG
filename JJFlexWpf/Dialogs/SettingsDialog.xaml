<local:JJFlexDialog x:Class="JJFlexWpf.Dialogs.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:JJFlexWpf"
    xmlns:controls="clr-namespace:JJFlexWpf.Controls"
    Title="Settings"
    Width="460" Height="540"
    ResizeMode="NoResize"
    AutomationProperties.Name="Settings">
    <DockPanel Margin="12">
        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Style="{StaticResource ButtonPanel}">
            <Button Content="_OK" AutomationProperties.AcceleratorKey="Alt+O" Style="{StaticResource OkButton}"
                    AutomationProperties.Name="OK"
                    Click="OkButton_Click"/>
            <Button Content="_Cancel" AutomationProperties.AcceleratorKey="Alt+C" Style="{StaticResource CancelButton}"
                    AutomationProperties.Name="Cancel"
                    Click="CancelButton_Click"/>
        </StackPanel>

        <!-- Tab control -->
        <TabControl x:Name="SettingsTabs"
                    AutomationProperties.Name="Settings categories">
            <!-- PTT Tab -->
            <TabItem Header="PTT" AutomationProperties.Name="Push to talk settings">
                <StackPanel Margin="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Timeout (seconds):"
                                   Style="{StaticResource DialogLabel}" Margin="0,4,8,4"/>
                        <TextBox x:Name="PttTimeoutBox" Grid.Row="0" Grid.Column="1"
                                 Style="{StaticResource DialogTextBox}"
                                 AutomationProperties.Name="PTT timeout in seconds, 10 to 900"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="First warning (seconds before timeout):"
                                   Style="{StaticResource DialogLabel}" Margin="0,4,8,4"/>
                        <TextBox x:Name="PttWarning1Box" Grid.Row="1" Grid.Column="1"
                                 Style="{StaticResource DialogTextBox}"
                                 AutomationProperties.Name="First warning, seconds before timeout"/>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Second warning (seconds before timeout):"
                                   Style="{StaticResource DialogLabel}" Margin="0,4,8,4"/>
                        <TextBox x:Name="PttWarning2Box" Grid.Row="2" Grid.Column="1"
                                 Style="{StaticResource DialogTextBox}"
                                 AutomationProperties.Name="Second warning, seconds before timeout"/>

                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="Final warning (seconds before timeout):"
                                   Style="{StaticResource DialogLabel}" Margin="0,4,8,4"/>
                        <TextBox x:Name="PttOhCrapBox" Grid.Row="3" Grid.Column="1"
                                 Style="{StaticResource DialogTextBox}"
                                 AutomationProperties.Name="Final warning, seconds before timeout"/>

                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Text="ALC auto-release (seconds, 0=off):"
                                   Style="{StaticResource DialogLabel}" Margin="0,4,8,4"/>
                        <TextBox x:Name="PttAlcBox" Grid.Row="4" Grid.Column="1"
                                 Style="{StaticResource DialogTextBox}"
                                 AutomationProperties.Name="ALC auto-release seconds, 0 to disable or 10 to 300"/>
                    </Grid>

                    <CheckBox x:Name="PttSpeechCheckbox"
                              Content="Announce transmit and receive state changes"
                              Margin="0,12,0,0"
                              AutomationProperties.Name="Announce transmit and receive state changes"/>

                    <CheckBox x:Name="ChirpEnabledCheckbox"
                              Content="Play chirp tones on transmit and receive"
                              Margin="0,8,0,0"
                              AutomationProperties.Name="Play chirp tones on transmit and receive"/>
                </StackPanel>
            </TabItem>

            <!-- Tuning Tab -->
            <TabItem Header="Tuning" AutomationProperties.Name="Tuning settings">
                <StackPanel Margin="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Coarse step default:"
                                   Style="{StaticResource DialogLabel}" Margin="0,4,8,4"/>
                        <ComboBox x:Name="CoarseStepCombo" Grid.Row="0" Grid.Column="1"
                                  Style="{StaticResource DialogComboBox}"
                                  AutomationProperties.Name="Default coarse tuning step"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Fine step default:"
                                   Style="{StaticResource DialogLabel}" Margin="0,4,8,4"/>
                        <ComboBox x:Name="FineStepCombo" Grid.Row="1" Grid.Column="1"
                                  Style="{StaticResource DialogComboBox}"
                                  AutomationProperties.Name="Default fine tuning step"/>
                    </Grid>

                    <Button Content="Edit _Tuning Steps..."
                            Width="160" HorizontalAlignment="Left" Margin="0,12,0,0"
                            AutomationProperties.Name="Edit tuning steps"
                            AutomationProperties.AcceleratorKey="Alt+T"
                            Click="EditTuningStepsButton_Click"/>

                    <CheckBox x:Name="BandMemoryCheckbox"
                              Content="Enable band memory"
                              IsChecked="True" Margin="0,12,0,0"
                              AutomationProperties.Name="Enable band memory"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="Frequency speech units:" VerticalAlignment="Center"
                                   Style="{StaticResource DialogLabel}" Margin="0,0,8,0"/>
                        <ComboBox x:Name="FreqUnitsCombo" Width="120"
                                  Style="{StaticResource DialogComboBox}"
                                  AutomationProperties.Name="Frequency speech units"/>
                    </StackPanel>

                    <Separator Margin="0,8,0,8"/>

                    <Button Content="Edit _Filter Presets..."
                            Width="160" HorizontalAlignment="Left"
                            AutomationProperties.Name="Edit filter presets"
                            AutomationProperties.AcceleratorKey="Alt+F"
                            Click="EditFilterPresetsButton_Click"/>

                    <Separator Margin="0,8,0,8"/>

                    <CheckBox x:Name="TuneDebounceCheckbox"
                              Content="Debounce tuning speech (group rapid steps)"
                              Margin="0,12,0,0"
                              AutomationProperties.Name="Debounce tuning speech, groups rapid tuning steps into one announcement"
                              Checked="TuneDebounceCheckbox_Changed"
                              Unchecked="TuneDebounceCheckbox_Changed"/>

                    <StackPanel x:Name="DebounceDelayPanel" Orientation="Horizontal" Margin="20,8,0,0">
                        <TextBlock Text="Debounce delay (ms):" VerticalAlignment="Center"
                                   Style="{StaticResource DialogLabel}" Margin="0,0,8,0"/>
                        <TextBox x:Name="DebounceDelayBox" Width="60"
                                 Style="{StaticResource DialogTextBox}"
                                 AutomationProperties.Name="Debounce delay in milliseconds, 50 to 1000"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- License Tab -->
            <TabItem Header="License" AutomationProperties.Name="License settings">
                <StackPanel Margin="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="License class:"
                                   Style="{StaticResource DialogLabel}" Margin="0,4,8,4"/>
                        <ComboBox x:Name="LicenseClassCombo" Grid.Row="0" Grid.Column="1"
                                  Style="{StaticResource DialogComboBox}"
                                  AutomationProperties.Name="FCC license class"/>
                    </Grid>

                    <CheckBox x:Name="BandBoundaryCheckbox"
                              Content="Band boundary notifications"
                              Margin="0,12,0,0"
                              AutomationProperties.Name="Notify when tuning near band boundaries"/>
                    <CheckBox x:Name="TxLockoutCheckbox"
                              Content="TX band lockout"
                              Margin="0,8,0,0"
                              AutomationProperties.Name="Prevent transmitting outside licensed bands"/>

                    <Separator Margin="0,12,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <TextBlock Text="Country:" VerticalAlignment="Center"
                                   Style="{StaticResource DialogLabel}" Margin="0,0,8,0"/>
                        <ComboBox x:Name="CountryCombo" Width="120"
                                  Style="{StaticResource DialogComboBox}"
                                  AutomationProperties.Name="Country for 60 meter channelization rules"/>
                    </StackPanel>

                    <CheckBox x:Name="EnforceTxRulesCheckbox"
                              Content="Enforce transmit rules (60m channels, power limits)"
                              Margin="0,8,0,0"
                              AutomationProperties.Name="Enforce transmit parameters based on published amateur radio rules"/>
                </StackPanel>
            </TabItem>

            <!-- Audio Tab (merged: alerts, meters, master volume) -->
            <TabItem Header="Audio" AutomationProperties.Name="Audio settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <!-- Master Volume -->
                    <controls:ValueFieldControl x:Name="MasterVolumeControl"
                        Margin="0,0,0,8"
                        AutomationProperties.Name="Master volume, 0 to 100, scales all audio"/>

                    <Separator Margin="0,4,0,8"/>

                    <!-- Alert section -->
                    <TextBlock Text="Alerts" FontWeight="SemiBold"
                               Style="{StaticResource DialogLabel}" Margin="0,0,0,4"/>
                    <controls:ValueFieldControl x:Name="EarconVolumeControl"
                        Margin="0,0,0,8"
                        AutomationProperties.Name="Alert volume, 0 to 100"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Alert device:"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource DialogLabel}" Margin="0,0,8,0"/>
                        <ComboBox x:Name="EarconDeviceCombo" Width="200"
                                  Style="{StaticResource DialogComboBox}"
                                  AutomationProperties.Name="Alert audio output device"/>
                    </StackPanel>

                    <Separator Margin="0,4,0,8"/>

                    <!-- Meter section -->
                    <TextBlock Text="Meter Tones" FontWeight="SemiBold"
                               Style="{StaticResource DialogLabel}" Margin="0,0,0,4"/>
                    <controls:ValueFieldControl x:Name="MeterVolumeControl"
                        Margin="0,0,0,8"
                        AutomationProperties.Name="Meter tone volume, 0 to 100"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Meter device:"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource DialogLabel}" Margin="0,0,8,0"/>
                        <ComboBox x:Name="MeterDeviceCombo" Width="200"
                                  Style="{StaticResource DialogComboBox}"
                                  AutomationProperties.Name="Meter tone audio output device"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Preset:"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource DialogLabel}" Margin="0,0,8,0"/>
                        <ComboBox x:Name="MeterPresetCombo" Width="150"
                                  Style="{StaticResource DialogComboBox}"
                                  AutomationProperties.Name="Meter tone preset"/>
                    </StackPanel>
                    <CheckBox x:Name="PeakWatcherCheck"
                              Content="Peak Watcher ALC alerts"
                              Margin="0,0,0,8"
                              AutomationProperties.Name="Enable Peak Watcher ALC alerts"/>
                    <CheckBox x:Name="MeterSpeechCheck"
                              Content="Meter speech readout"
                              Margin="0,0,0,8"
                              AutomationProperties.Name="Enable meter speech readout"/>

                    <Separator Margin="0,4,0,8"/>

                    <!-- Typing sound -->
                    <TextBlock Text="Frequency Entry" FontWeight="SemiBold"
                               Style="{StaticResource DialogLabel}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Typing sound:"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource DialogLabel}" Margin="0,0,8,0"/>
                        <ComboBox x:Name="TypingSoundCombo" Width="180"
                                  Style="{StaticResource DialogComboBox}"
                                  AutomationProperties.Name="Frequency entry typing sound mode"/>
                    </StackPanel>

                    <Separator Margin="0,4,0,8"/>

                    <!-- Braille Display section -->
                    <TextBlock Text="Braille Display" FontWeight="SemiBold"
                               Style="{StaticResource DialogLabel}" Margin="0,0,0,4"/>
                    <CheckBox x:Name="BrailleEnabledCheck"
                              Content="Enable braille status line"
                              Margin="0,0,0,8"
                              AutomationProperties.Name="Enable braille status line on home position"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Display cells:"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource DialogLabel}" Margin="0,0,8,0"/>
                        <ComboBox x:Name="BrailleCellsCombo" Width="80"
                                  Style="{StaticResource DialogComboBox}"
                                  AutomationProperties.Name="Braille display cell count"/>
                    </StackPanel>

                    <Separator Margin="0,4,0,8"/>

                    <!-- Audio Workshop shortcut -->
                    <Button Content="Audio _Workshop..."
                            Width="160" HorizontalAlignment="Left"
                            AutomationProperties.Name="Audio Workshop"
                            AutomationProperties.AcceleratorKey="Alt+W"
                            Click="AudioWorkshopButton_Click"/>
                </StackPanel>
                </ScrollViewer>
            </TabItem>
            <!-- Network Tab (SmartLink port forwarding) -->
            <TabItem Header="Network" AutomationProperties.Name="Network and SmartLink settings">
                <StackPanel Margin="8">
                    <TextBlock Text="SmartLink Port Forwarding" FontWeight="SemiBold"
                               Style="{StaticResource DialogLabel}" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,8"
                               Text="Configure the radio's firmware to listen on a specific port for SmartLink. Your router must also forward the same TCP and UDP port to the radio's LAN IP address. Requires an active radio connection."/>

                    <TextBlock x:Name="NetworkCurrentStateText"
                               Style="{StaticResource DialogLabel}" Margin="0,0,0,8"
                               AutomationProperties.LiveSetting="Polite"/>

                    <CheckBox x:Name="PortForwardEnabledCheck"
                              Content="Enable manual port forwarding"
                              Margin="0,0,0,8"
                              AutomationProperties.Name="Enable manual port forwarding on the radio"/>

                    <Grid Margin="20,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Port (TCP and UDP):"
                                   x:Name="PortForwardTcpLabel"
                                   Style="{StaticResource DialogLabel}" Margin="0,4,8,4"/>
                        <TextBox x:Name="PortForwardTcpBox" Grid.Row="0" Grid.Column="1"
                                 Text="4992"
                                 Style="{StaticResource DialogTextBox}"
                                 AutomationProperties.Name="Port number, 1024 to 65535, applied to TCP and UDP"
                                 TextChanged="PortForwardTcpBox_TextChanged"/>
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="UDP port:"
                                   Style="{StaticResource DialogLabel}" Margin="0,4,8,4"/>
                        <TextBox x:Name="PortForwardUdpBox" Grid.Row="1" Grid.Column="1"
                                 Text="4992" IsEnabled="False"
                                 Style="{StaticResource DialogTextBox}"
                                 AutomationProperties.Name="UDP port number, 1024 to 65535"/>
                    </Grid>

                    <CheckBox x:Name="PortForwardSeparatePortsCheck"
                              Content="Use different TCP and UDP ports (advanced)"
                              Margin="20,0,0,8"
                              AutomationProperties.Name="Allow different TCP and UDP ports"
                              Checked="PortForwardSeparatePortsCheck_Changed"
                              Unchecked="PortForwardSeparatePortsCheck_Changed"/>

                    <Button Content="_Apply to connected radio"
                            Width="220" HorizontalAlignment="Left" Margin="0,4,0,0"
                            AutomationProperties.Name="Apply port forwarding to connected radio"
                            AutomationProperties.AcceleratorKey="Alt+A"
                            Click="ApplyPortForwardButton_Click"/>
                </StackPanel>
            </TabItem>

            <!-- Verbosity & Notifications Tab -->
            <TabItem Header="Notifications" AutomationProperties.Name="Verbosity and notifications settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <!-- Speech section -->
                    <TextBlock Text="Speech" FontWeight="SemiBold"
                               Style="{StaticResource DialogLabel}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Speech verbosity:"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource DialogLabel}" Margin="0,0,8,0"/>
                        <ComboBox x:Name="SpeechVerbosityCombo" Width="120"
                                  Style="{StaticResource DialogComboBox}"
                                  AutomationProperties.Name="Speech verbosity level"/>
                    </StackPanel>

                    <Separator Margin="0,4,0,8"/>

                    <!-- Earcons section -->
                    <TextBlock Text="Alert Sounds" FontWeight="SemiBold"
                               Style="{StaticResource DialogLabel}" Margin="0,0,0,4"/>
                    <CheckBox x:Name="EarconsEnabledCheck"
                              Content="Enable alert sounds (earcons)"
                              Margin="0,0,0,8"
                              AutomationProperties.Name="Enable alert sounds such as beeps and tones"/>

                    <Separator Margin="0,4,0,8"/>

                    <!-- CW Notifications section -->
                    <TextBlock Text="CW Morse Notifications" FontWeight="SemiBold"
                               Style="{StaticResource DialogLabel}" Margin="0,0,0,4"/>
                    <CheckBox x:Name="CwNotificationsCheck"
                              Content="Enable CW notifications (AS, BT, SK prosigns)"
                              Margin="0,0,0,8"
                              AutomationProperties.Name="Enable Morse code notifications for connection events"/>
                    <Grid Margin="20,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Sidetone frequency (Hz):"
                                   Style="{StaticResource DialogLabel}" Margin="0,4,8,4"/>
                        <TextBox x:Name="CwSidetoneBox" Grid.Row="0" Grid.Column="1"
                                 Style="{StaticResource DialogTextBox}"
                                 AutomationProperties.Name="CW sidetone frequency, 400 to 1200 hertz"/>
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Speed (WPM):"
                                   Style="{StaticResource DialogLabel}" Margin="0,4,8,4"/>
                        <TextBox x:Name="CwSpeedBox" Grid.Row="1" Grid.Column="1"
                                 Style="{StaticResource DialogTextBox}"
                                 AutomationProperties.Name="CW notification speed, 10 to 30 words per minute"/>
                    </Grid>
                    <CheckBox x:Name="CwModeAnnounceCheck"
                              Content="Announce mode changes in CW (when speech is off)"
                              Margin="0,0,0,8"
                              AutomationProperties.Name="Play mode name in Morse code when speech verbosity is off"/>

                    <Separator Margin="0,4,0,8"/>

                    <!-- Meter Tones enable (moved from Audio) -->
                    <TextBlock Text="Meter Tones" FontWeight="SemiBold"
                               Style="{StaticResource DialogLabel}" Margin="0,0,0,4"/>
                    <CheckBox x:Name="MeterTonesNotifCheck"
                              Content="Enable meter tones"
                              Margin="0,0,0,8"
                              AutomationProperties.Name="Enable meter tones"/>

                    <Separator Margin="0,4,0,8"/>

                    <!-- Display elements -->
                    <TextBlock Text="Display" FontWeight="SemiBold"
                               Style="{StaticResource DialogLabel}" Margin="0,0,0,4"/>
                    <CheckBox x:Name="ShowPanadapterCheck"
                              Content="Show panadapter / waterfall display"
                              Margin="0,0,0,8"
                              AutomationProperties.Name="Show the panadapter and waterfall display. When unchecked, the display is hidden from view and removed from the tab order and braille refreshes are suppressed."/>

                    <Separator Margin="0,4,0,8"/>

                    <!-- Tune feedback -->
                    <TextBlock Text="Tune Feedback" FontWeight="SemiBold"
                               Style="{StaticResource DialogLabel}" Margin="0,0,0,4"/>
                    <CheckBox x:Name="AnnounceSwrAfterTuneCheck"
                              Content="Read final SWR reading after manual or automatic tune"
                              Margin="0,0,0,8"
                              AutomationProperties.Name="Read final SWR reading after manual or automatic tune."/>
                </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</local:JJFlexDialog>
