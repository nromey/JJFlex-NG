<local:JJFlexDialog x:Class="JJFlexWpf.Dialogs.AudioWorkshopDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JJFlexWpf"
        Title="Audio Workshop"
        Width="500" Height="620"
        ShowInTaskbar="True"
        ResizeMode="CanResize"
        AutomationProperties.Name="Audio Workshop">
    <DockPanel>
        <!-- Toolbar at top -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8,4">
            <Button x:Name="LoadPresetButton" Content="Load Preset" Margin="0,0,4,0" Padding="8,4"
                    AutomationProperties.Name="Load audio preset" Click="LoadPreset_Click"/>
            <Button x:Name="SavePresetButton" Content="Save Preset" Margin="0,0,4,0" Padding="8,4"
                    AutomationProperties.Name="Save current settings as audio preset" Click="SavePreset_Click"/>
            <Button x:Name="ExportButton" Content="Export" Margin="0,0,4,0" Padding="8,4"
                    AutomationProperties.Name="Export preset to file" Click="Export_Click"/>
            <Button x:Name="ResetButton" Content="Reset" Margin="0,0,4,0" Padding="8,4"
                    AutomationProperties.Name="Reset to defaults" Click="Reset_Click"/>
        </StackPanel>

        <TabControl x:Name="MainTabs" Margin="4">
            <!-- Tab 1: TX Audio -->
            <TabItem Header="TX Audio" AutomationProperties.Name="TX Audio Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False">
                    <StackPanel x:Name="TxAudioContent" Margin="8"
                                KeyboardNavigation.TabNavigation="Cycle" />
                </ScrollViewer>
            </TabItem>

            <!-- Tab 2: Live Meters -->
            <TabItem Header="Live Meters" AutomationProperties.Name="Live Meter Readings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False">
                    <StackPanel x:Name="LiveMetersContent" Margin="8"
                                KeyboardNavigation.TabNavigation="Cycle" />
                </ScrollViewer>
            </TabItem>

            <!-- Tab 3: Earcon Explorer -->
            <TabItem Header="Earcon Explorer" AutomationProperties.Name="Earcon Sound Explorer">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False">
                    <StackPanel x:Name="EarconExplorerContent" Margin="8"
                                KeyboardNavigation.TabNavigation="Cycle" />
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</local:JJFlexDialog>
