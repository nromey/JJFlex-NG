<local:JJFlexDialog x:Class="JJFlexWpf.Dialogs.RigSelectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JJFlexWpf"
        Title="Select Radio"
        Width="480" Height="420"
        ResizeMode="NoResize"
        AutomationProperties.Name="Radio selector"
        Closing="RigSelectorDialog_Closing">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Label -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Available Radios:"
                   Margin="0,0,0,4"
                   AutomationProperties.Name="Available radios list"/>

        <!-- Radio list -->
        <ListBox x:Name="RadiosBox" Grid.Row="1" Grid.Column="0"
                 Margin="0,0,8,0"
                 Focusable="True"
                 IsTabStop="True"
                 KeyboardNavigation.TabNavigation="Once"
                 AutomationProperties.Name="Radio list, searching for radios"
                 GotFocus="RadiosBox_GotFocus"
                 LostFocus="RadiosBox_LostFocus"
                 SelectionChanged="RadiosBox_SelectionChanged">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Connect" Click="ConnectMenuItem_Click"
                              AutomationProperties.Name="Connect to selected radio"/>
                    <MenuItem Header="Low BW Toggle" Click="LowBWMenuItem_Click"
                              AutomationProperties.Name="Toggle low bandwidth mode"/>
                    <MenuItem x:Name="AutoConnectMenuItem" Header="Auto-Connect Settings..."
                              Click="AutoConnectMenuItem_Click"
                              AutomationProperties.Name="Auto-connect settings for selected radio"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>

        <!-- Action buttons -->
        <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Top">
            <Button x:Name="ConnectButton" Content="Co_nnect" MinWidth="100" Height="28" Margin="0,0,0,8"
                    AutomationProperties.Name="Connect"
                    AutomationProperties.AcceleratorKey="Alt+N"
                    Click="ConnectButton_Click"/>
            <Button Content="_Low BW" MinWidth="100" Height="28" Margin="0,0,0,8"
                    AutomationProperties.Name="Low BW"
                    AutomationProperties.AcceleratorKey="Alt+L"
                    Click="LowBWButton_Click"/>
            <Button Content="_Remote" MinWidth="100" Height="28" Margin="0,0,0,8"
                    AutomationProperties.Name="Remote"
                    AutomationProperties.AcceleratorKey="Alt+R"
                    Click="RemoteButton_Click"/>
            <Button Content="_Switch Account" MinWidth="100" Height="28" Margin="0,0,0,8"
                    AutomationProperties.Name="Switch Account"
                    AutomationProperties.AcceleratorKey="Alt+S"
                    Click="SwitchAccountButton_Click"/>
            <Button x:Name="TestButton" Content="_Test" MinWidth="100" Height="28" Margin="0,0,0,8"
                    AutomationProperties.Name="Test"
                    AutomationProperties.AcceleratorKey="Alt+T"
                    Click="TestButton_Click"/>
            <Button x:Name="AutoConnectButton" Content="_Auto-Connect" MinWidth="100" Height="28" Margin="0,0,0,8"
                    AutomationProperties.Name="Auto-Connect"
                    AutomationProperties.AcceleratorKey="Alt+A"
                    IsEnabled="False"
                    Click="AutoConnectButton_Click"/>
            <Button Content="_Cancel" AutomationProperties.AcceleratorKey="Alt+C" MinWidth="100" Height="28" IsCancel="True"
                    AutomationProperties.Name="Cancel"
                    Click="CancelButton_Click"/>
        </StackPanel>

        <!-- Global auto-connect checkbox -->
        <CheckBox x:Name="GlobalAutoConnectCheckbox" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                  Content="Enable auto-connect on startup" Margin="0,8,0,0"
                  AutomationProperties.Name="Enable auto-connect on startup"
                  Checked="GlobalAutoConnectCheckbox_Changed"
                  Unchecked="GlobalAutoConnectCheckbox_Changed"/>

        <!-- Row 3 reserved for future use -->
    </Grid>
</local:JJFlexDialog>
