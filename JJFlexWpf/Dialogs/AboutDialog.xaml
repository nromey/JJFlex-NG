<local:JJFlexDialog x:Class="JJFlexWpf.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JJFlexWpf"
        Title="About JJ Flexible Radio Access"
        Width="520" Height="460"
        ResizeMode="NoResize"
        AutomationProperties.Name="About JJ Flexible Radio Access">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tabbed content -->
        <TabControl x:Name="AboutTabs" Grid.Row="0"
                    AutomationProperties.Name="About information tabs">
            <!-- Tab 1: About -->
            <TabItem Header="About" AutomationProperties.Name="About">
                <TextBox x:Name="AboutText" IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="8"
                         AutomationProperties.Name="About information"
                         BorderThickness="0" Background="Transparent"/>
            </TabItem>

            <!-- Tab 2: Radio -->
            <TabItem Header="Radio" AutomationProperties.Name="Radio">
                <TextBox x:Name="RadioText" IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="8"
                         AutomationProperties.Name="Radio information"
                         BorderThickness="0" Background="Transparent"/>
            </TabItem>

            <!-- Tab 3: System -->
            <TabItem Header="System" AutomationProperties.Name="System">
                <TextBox x:Name="SystemText" IsReadOnly="True"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="8"
                         AutomationProperties.Name="System information"
                         BorderThickness="0" Background="Transparent"/>
            </TabItem>

            <!-- Tab 4: Diagnostics -->
            <TabItem Header="Diagnostics" AutomationProperties.Name="Diagnostics">
                <StackPanel Margin="8">
                    <TextBox x:Name="DiagnosticsText" IsReadOnly="True"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             Height="180"
                             VerticalScrollBarVisibility="Auto"
                             AutomationProperties.Name="Diagnostics information"
                             BorderThickness="0" Background="Transparent"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Check for Updates" MinWidth="130" Height="28" Margin="0,0,8,0"
                                AutomationProperties.Name="Check for updates"
                                Click="CheckUpdatesButton_Click"/>
                        <Button Content="Run Connection Test" MinWidth="140" Height="28"
                                AutomationProperties.Name="Run connection test"
                                x:Name="ConnectionTestButton"
                                Click="ConnectionTestButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Copy to Clipboard" MinWidth="120" Height="28" Margin="0,0,8,0"
                    AutomationProperties.Name="Copy all information to clipboard"
                    Click="CopyButton_Click"/>
            <Button Content="Export Diagnostic Report" MinWidth="160" Height="28" Margin="0,0,8,0"
                    AutomationProperties.Name="Export diagnostic report to file"
                    Click="ExportButton_Click"/>
            <Button Content="Close" MinWidth="80" Height="28"
                    IsDefault="True" IsCancel="True"
                    AutomationProperties.Name="Close"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</local:JJFlexDialog>
