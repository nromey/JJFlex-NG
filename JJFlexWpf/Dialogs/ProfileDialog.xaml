<local:JJFlexDialog x:Class="JJFlexWpf.Dialogs.ProfileDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JJFlexWpf"
        Title="Profiles"
        Width="450" Height="380"
        ResizeMode="NoResize"
        AutomationProperties.Name="Profile manager">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Label -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Profiles:"
                   Style="{StaticResource DialogLabel}" Margin="0,0,0,4"/>

        <!-- Profile list -->
        <ListBox x:Name="ProfilesListBox" Grid.Row="1" Grid.Column="0"
                 Margin="0,0,8,0"
                 AutomationProperties.Name="Profile list"
                 SelectionChanged="ProfilesListBox_SelectionChanged"/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Top">
            <Button Content="Se_lect" MinWidth="90" Height="28" Margin="0,0,0,8"
                    AutomationProperties.Name="Select"
                    AutomationProperties.AcceleratorKey="Alt+L"
                    Click="SelectButton_Click"/>
            <Button Content="_Add" MinWidth="90" Height="28" Margin="0,0,0,8"
                    AutomationProperties.Name="Add"
                    AutomationProperties.AcceleratorKey="Alt+A"
                    Click="AddButton_Click"/>
            <Button Content="_Update" MinWidth="90" Height="28" Margin="0,0,0,8"
                    AutomationProperties.Name="Update"
                    AutomationProperties.AcceleratorKey="Alt+U"
                    Click="UpdateButton_Click"/>
            <Button Content="_Delete" MinWidth="90" Height="28" Margin="0,0,0,8"
                    AutomationProperties.Name="Delete"
                    AutomationProperties.AcceleratorKey="Alt+D"
                    Click="DeleteButton_Click"/>
            <Button x:Name="SaveButton" Content="_Save" AutomationProperties.AcceleratorKey="Alt+S" MinWidth="90" Height="28" Margin="0,0,0,8"
                    Visibility="Collapsed"
                    AutomationProperties.Name="Save profile to radio"
                    Click="SaveButton_Click"/>
        </StackPanel>

        <!-- Close button -->
        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                    Style="{StaticResource ButtonPanel}" Margin="0,8,0,0">
            <Button Content="_Close" AutomationProperties.AcceleratorKey="Alt+C" Style="{StaticResource CancelButton}"
                    AutomationProperties.Name="Close profile manager"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</local:JJFlexDialog>
