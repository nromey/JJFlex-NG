<local:JJFlexDialog x:Class="JJFlexWpf.Dialogs.CommandFinderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JJFlexWpf"
        Title="Command Finder"
        Width="500" Height="420"
        ResizeMode="CanResizeWithGrip">
    <DockPanel Margin="12">
        <!-- Category filter above search (top-down flow: category → search → results) -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Label Content="Category:" DockPanel.Dock="Left" Padding="0,0,8,0"
                   VerticalAlignment="Center" />
            <ComboBox x:Name="CategoryCombo"
                      AutomationProperties.Name="Category"
                      DropDownClosed="CategoryCombo_SelectionCommitted"
                      SelectionChanged="CategoryCombo_SelectionChanged"
                      VerticalAlignment="Center" />
        </DockPanel>
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <Label Content="Search:" DockPanel.Dock="Left" Padding="0,0,8,0"
                   VerticalAlignment="Center" />
            <TextBox x:Name="SearchBox"
                     AutomationProperties.Name="Search commands"
                     TextChanged="SearchBox_TextChanged"
                     VerticalAlignment="Center" />
        </DockPanel>
        <CheckBox x:Name="ShowAllScopesCheckBox" DockPanel.Dock="Top"
                  Content="Show all commands"
                  Margin="0,0,0,8"
                  AutomationProperties.Name="Show commands from all modes"
                  IsChecked="False"
                  Checked="OnScopeFilterChanged" Unchecked="OnScopeFilterChanged" />
        <TextBlock x:Name="ResultCountLabel" DockPanel.Dock="Bottom"
                   Margin="0,4,0,0" Foreground="Gray"
                   AutomationProperties.Name="Result count"
                   AutomationProperties.LiveSetting="Polite" />
        <ListView x:Name="ResultsListView"
                  AutomationProperties.Name="Command results"
                  MouseDoubleClick="ResultsListView_DoubleClick"
                  KeyDown="ResultsListView_KeyDown">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Command" Width="220"
                                    DisplayMemberBinding="{Binding Description}" />
                    <GridViewColumn Header="Key" Width="100"
                                    DisplayMemberBinding="{Binding KeyDisplay}" />
                    <GridViewColumn Header="Scope" Width="80"
                                    DisplayMemberBinding="{Binding Scope}" />
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</local:JJFlexDialog>
