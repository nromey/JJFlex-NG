<local:JJFlexDialog x:Class="JJFlexWpf.Dialogs.EarconScratchpadDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JJFlexWpf"
        Title="Earcon Scratchpad"
        Width="420" Height="400"
        ResizeMode="NoResize"
        AutomationProperties.Name="Earcon scratchpad, design your own sounds">
    <StackPanel Margin="12">
        <TextBlock Text="Tone Generator" FontWeight="Bold" Margin="0,0,0,8" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <!-- Start Frequency -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Start Hz:" VerticalAlignment="Center" Margin="0,0,8,4"/>
            <Slider x:Name="StartFreqSlider" Grid.Row="0" Grid.Column="1" Minimum="100" Maximum="2000" Value="800"
                    AutomationProperties.Name="Start frequency" Margin="0,0,8,4"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBox x:Name="StartFreqBox" Grid.Row="0" Grid.Column="2" Text="800" VerticalAlignment="Center" Margin="0,0,0,4"
                     AutomationProperties.Name="Start frequency hertz" TextChanged="FreqBox_TextChanged"/>

            <!-- End Frequency (for sweep) -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="End Hz:" VerticalAlignment="Center" Margin="0,0,8,4"/>
            <Slider x:Name="EndFreqSlider" Grid.Row="1" Grid.Column="1" Minimum="100" Maximum="2000" Value="800"
                    AutomationProperties.Name="End frequency for sweep" Margin="0,0,8,4"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBox x:Name="EndFreqBox" Grid.Row="1" Grid.Column="2" Text="800" VerticalAlignment="Center" Margin="0,0,0,4"
                     AutomationProperties.Name="End frequency hertz" TextChanged="FreqBox_TextChanged"/>

            <!-- Duration -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Duration ms:" VerticalAlignment="Center" Margin="0,0,8,4"/>
            <Slider x:Name="DurationSlider" Grid.Row="2" Grid.Column="1" Minimum="10" Maximum="1000" Value="200"
                    AutomationProperties.Name="Duration milliseconds" Margin="0,0,8,4"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBox x:Name="DurationBox" Grid.Row="2" Grid.Column="2" Text="200" VerticalAlignment="Center" Margin="0,0,0,4"
                     AutomationProperties.Name="Duration milliseconds" TextChanged="FreqBox_TextChanged"/>

            <!-- Volume -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Volume:" VerticalAlignment="Center" Margin="0,0,8,4"/>
            <Slider x:Name="VolumeSlider" Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="100" Value="60"
                    AutomationProperties.Name="Volume percent" Margin="0,0,8,4"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBox x:Name="VolumeBox" Grid.Row="3" Grid.Column="2" Text="60" VerticalAlignment="Center" Margin="0,0,0,4"
                     AutomationProperties.Name="Volume percent" TextChanged="FreqBox_TextChanged"/>

            <!-- Pan -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Pan:" VerticalAlignment="Center" Margin="0,0,8,4"/>
            <Slider x:Name="PanSlider" Grid.Row="4" Grid.Column="1" Minimum="-100" Maximum="100" Value="0"
                    AutomationProperties.Name="Pan, negative left, positive right" Margin="0,0,8,4"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBox x:Name="PanBox" Grid.Row="4" Grid.Column="2" Text="0" VerticalAlignment="Center" Margin="0,0,0,4"
                     AutomationProperties.Name="Pan, negative 100 left, 0 center, 100 right" TextChanged="FreqBox_TextChanged"/>
        </Grid>

        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="PlayToneButton" Content="Play Tone" Width="100" Height="28" Margin="0,0,8,0"
                    AutomationProperties.Name="Play tone" Click="PlayTone_Click"/>
            <Button x:Name="PlaySweepButton" Content="Play Sweep" Width="100" Height="28" Margin="0,0,8,0"
                    AutomationProperties.Name="Play sweep from start to end frequency" Click="PlaySweep_Click"/>
            <Button x:Name="PlaySlideButton" Content="Play Slide" Width="100" Height="28" Margin="0,0,8,0"
                    AutomationProperties.Name="Play slide sound with current pan" Click="PlaySlide_Click"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Play Zip" Width="100" Height="28" Margin="0,0,8,0"
                    AutomationProperties.Name="Play zip sound with current pan" Click="PlayZip_Click"/>
            <Button Content="Play Zip Reversed" Width="100" Height="28" Margin="0,0,8,0"
                    AutomationProperties.Name="Play zip sound reversed with current pan" Click="PlayZipReversed_Click"/>
        </StackPanel>

        <TextBlock Text="Filter Sounds" FontWeight="Bold" Margin="0,12,0,4" />
        <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
            <Button Content="Squeeze" Width="100" Height="28" Margin="0,0,8,0"
                    AutomationProperties.Name="Play filter squeeze sound" Click="PlaySqueeze_Click"/>
            <Button Content="Stretch" Width="100" Height="28" Margin="0,0,8,0"
                    AutomationProperties.Name="Play filter stretch sound" Click="PlayStretch_Click"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" Margin="0,12,0,0" TextWrapping="Wrap"
                   AutomationProperties.Name="Status" AutomationProperties.LiveSetting="Polite"/>
    </StackPanel>
</local:JJFlexDialog>
